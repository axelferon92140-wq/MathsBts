<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>MathMagique</title>

<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#6C63FF">

<link rel="manifest" href="manifest.json">
<link rel="stylesheet" href="style.css">

<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;700&display=swap" rel="stylesheet">
</head>

<body>

<header>✨ MathMagique</header>

<div class="nav">
<button onclick="show('cours')">Cours</button>
<button onclick="show('quiz')">Quiz</button>
<button onclick="show('profil')">Profil</button>
</div>

<!-- COURS -->
<div id="cours" class="section active">

<div class="card">
<h3>📚 Bases</h3>
<p>Addition, multiplication, etc.</p>
</div>

<div id="premiumCours" class="card lock">
<h3>🔒 Premium</h3>
<p>Fractions, équations, logique</p>
<button onclick="goStripe()">Débloquer</button>
</div>

</div>

<!-- QUIZ -->
<div id="quiz" class="section">
<div class="card">
<h2 id="question"></h2>
<input type="number" id="answer">
<button onclick="check()">Valider</button>
<div id="feedback"></div>
<div class="score" id="score"></div>
</div>
</div>

<!-- PROFIL -->
<div id="profil" class="section">
<div class="card">
<h3>👤 Ton profil</h3>
<p id="level"></p>
<p id="xp"></p>
<p id="best"></p>
</div>
</div>

<script src="app.js"></script>

</body>
</html>